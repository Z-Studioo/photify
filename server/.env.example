# Environment Configuration
NODE_ENV=development
PORT=5000

# Client Configuration
CLIENT_URL=http://localhost:5173

# Security
JWT_SECRET=your-super-secret-jwt-key-here-make-it-at-least-32-characters-long

# Logging
LOG_LEVEL=info

# API Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Supabase Configuration
SUPABASE_URL=your-supabase-project-url
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# Stripe Configuration
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret

# PostCoder Address Lookup
POSTCODER_API_KEY=your-postcoder-api-key

# SendGrid Configuration (for contact form emails)
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@photify.co
SUPPORT_EMAIL=support@photify.co
ADMIN_EMAIL=test@test.com # for receiving order mails

# Analytics — GA4 Measurement Protocol (server-side `purchase` / `refund`).
# Both vars are required for server-side reporting; missing them turns the
# feature off cleanly (the Stripe webhook still processes orders normally).
# Server-side events are additionally gated on PUBLIC_APP_URL being
# https://photify.co or https://www.photify.co, so non-live deploys never
# call Google.
GA4_MEASUREMENT_ID=G-XXXXXXXX
GA4_API_SECRET=your-ga4-measurement-protocol-api-secret