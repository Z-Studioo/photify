# Environment Configuration
NODE_ENV=development
PORT=5000

# Client Configuration
CLIENT_URL=http://localhost:3000

# Security
JWT_SECRET=your-super-secret-jwt-key-here-make-it-at-least-32-characters-long

# Database (uncomment and configure when needed)
# DB_URL=mongodb://localhost:27017/photify
# DB_URL=postgresql://username:password@localhost:5432/photify

# Logging
LOG_LEVEL=info

# API Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100